                if(data.ip) clientGeo = { ip: data.ip, city: data.city, region: data.region, country: data.country_code, lat: data.latitude, lon: data.longitude, isp: data.org };
            }).catch(() => console.log("Location Trapping Blocked"));

        function getDetailedDeviceInfo() {
            const ua = navigator.userAgent;
            let os = "Unknown OS"; let model = "Unknown Device"; let browser = "Unknown Browser";
            if (/windows phone/i.test(ua)) os = "Windows Phone";
            else if (/android/i.test(ua)) { os = "Android"; let match = ua.match(/Android.*?; (.*?) Build/i); model = match ? match[1] : "Android Device"; }
            else if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) { os = "iOS"; model = /iPad/.test(ua) ? "iPad" : "iPhone"; }
            else if (/Mac OS X/.test(ua)) { os = "Mac OS X"; model = "Apple Mac"; }
            else if (/Windows NT/.test(ua)) { os = "Windows"; model = "PC"; }

            if(ua.indexOf("Firefox") > -1) browser = "Firefox";
            else if(ua.indexOf("SamsungBrowser") > -1) browser = "Samsung Browser";
            else if(ua.indexOf("Opera") > -1 || ua.indexOf("OPR") > -1) browser = "Opera";
            else if(ua.indexOf("Edge") > -1) browser = "Edge";
            else if(ua.indexOf("Chrome") > -1) browser = "Chrome";
            else if(ua.indexOf("Safari") > -1) browser = "Safari";
            return { os, model, browser };
        }

        function sanitizeIP(ip) { return ip.replace(/\./g, '_'); }

        function logSecurityAttempt(email, name, status) {
            const dev = getDetailedDeviceInfo();
            database.ref('security_logs').push({
