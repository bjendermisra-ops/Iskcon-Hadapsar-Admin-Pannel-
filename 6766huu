        // Tracker Info
        let clientGeo = { ip: "Unknown", city: "Unknown", region: "Unknown", country: "Unknown", lat: "0", lon: "0", isp: "Unknown" };
        
        fetch('https://ipapi.co/json/') // Using HTTPS supported API
            .then(res => res.json())
