<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ISKCON Hadapsar - Master Admin Portal</title>
    <!-- Tailwind CSS for Powerful UI -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Plus Jakarta Sans for Enterprise Look -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Firebase SDKs -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans:['"Plus Jakarta Sans"', 'sans-serif'] },
                    colors: { iskcon: { 50: '#fff7ed', 100: '#ffedd5', 500: '#f97316', 600: '#ea580c', 900: '#7c2d12' }, darkbg: '#0a0f1c', darkcard: '#111827' },
                    animation: { 'fade-in-up': 'fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards', 'blob': 'blob 7s infinite', 'float': 'float 6s ease-in-out infinite', 'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite' },
                    keyframes: {
                        fadeInUp: { '0%': { opacity: '0', transform: 'translateY(20px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } },
                        blob: { '0%, 100%': { transform: 'translate(0px, 0px) scale(1)' }, '33%': { transform: 'translate(30px, -50px) scale(1.1)' }, '66%': { transform: 'translate(-20px, 20px) scale(0.9)' } },
                        float: { '0%, 100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-10px)' } }
                    }
                }
            }
        }
    </script>
    <style>
        body { transition: background-color 0.4s ease, color 0.4s ease; overflow-x: hidden; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.4); }
        .dark .glass { background: rgba(17, 24, 39, 0.7); border: 1px solid rgba(255, 255, 255, 0.05); }
        .module-card { transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; cursor: pointer; }
        .module-card::after { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0) 100%); transform: skewX(-25deg); z-index: 1; pointer-events: none; }
        .dark .module-card::after { background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0) 100%); }
        .module-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.1); }
        .dark .module-card:hover { box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.5); }
        .module-card:hover::after { animation: shine 0.8s ease-out forwards; }
        @keyframes shine { 100% { left: 200%; } }
        .module-card:hover .card-icon { transform: scale(1.1) rotate(5deg); }
        .card-icon { transition: transform 0.3s ease; }
        .delay-100 { animation-delay: 50ms; } .delay-200 { animation-delay: 100ms; } .delay-300 { animation-delay: 150ms; } .delay-400 { animation-delay: 200ms; } .delay-500 { animation-delay: 250ms; } .delay-600 { animation-delay: 300ms; } .delay-700 { animation-delay: 350ms; }
        .bg-blobs { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; overflow: hidden; pointer-events: none; }
        .blob-1 { position: absolute; top: -10%; left: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(249, 115, 22, 0.15) 0%, transparent 70%); border-radius: 50%; filter: blur(40px); }
        .dark .blob-1 { background: radial-gradient(circle, rgba(249, 115, 22, 0.1) 0%, transparent 70%); }
        .blob-2 { position: absolute; bottom: -20%; right: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%); border-radius: 50%; filter: blur(40px); animation-delay: 2s; }
        .dark .blob-2 { background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%); }
        ::-webkit-scrollbar { width: 8px; } ::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.05); } .dark ::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.05); } ::-webkit-scrollbar-thumb { background: rgba(249, 115, 22, 0.5); border-radius: 10px; } ::-webkit-scrollbar-thumb:hover { background: rgba(249, 115, 22, 0.8); }
        
        /* Mobile Menu Transitions */
        #mobileMenuOverlay { transition: opacity 0.3s ease; }
        #mobileMenuDrawer { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 dark:bg-darkbg dark:text-slate-100 font-sans antialiased min-h-screen flex flex-col relative">

    <div class="bg-blobs">
        <div class="blob-1 animate-blob"></div>
        <div class="blob-2 animate-blob"></div>
    </div>

    <!-- LOGIN SCREEN -->
    <div id="login-section" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-50/95 dark:bg-darkbg/95 backdrop-blur-xl transition-opacity duration-500 p-4">
        <div class="glass w-full max-w-md rounded-3xl p-6 md:p-8 shadow-2xl border border-white dark:border-slate-800 relative overflow-hidden transform transition-all animate-fade-in-up">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-iskcon-500 via-orange-400 to-yellow-400"></div>
            
            <div class="text-center mb-6">
                <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-iskcon-100 to-white dark:from-slate-800 dark:to-slate-900 flex items-center justify-center shadow-lg border border-iskcon-200 dark:border-slate-700 mb-3 animate-float">
                    <span class="text-2xl font-black text-iskcon-500">IH</span>
                </div>
                <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight">ISKCON Hadapsar</h2>
                <p data-i18n="secureLoginTitle" class="text-xs font-bold text-iskcon-500 mt-1 uppercase tracking-widest">Master Authority Login</p>
            </div>

            <form id="loginForm" class="space-y-4">
                <div id="loginError" class="hidden bg-red-100 border-l-4 border-red-600 text-red-800 p-3 rounded-xl text-sm font-bold shadow-sm flex items-start gap-2">
                    <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
                    <span id="loginErrorText">Error message here</span>
                </div>
                
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-user text-slate-400"></i></div>
                    <input type="text" id="adminName" required class="block w-full pl-10 pr-3 py-3 border border-slate-300 dark:border-slate-700 rounded-xl leading-5 bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-iskcon-500 sm:text-sm transition-all" placeholder="Your Full Name">
                </div>

                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-language text-slate-400"></i></div>
                    <select id="adminLang" required class="block w-full pl-10 pr-3 py-3 border border-slate-300 dark:border-slate-700 rounded-xl leading-5 bg-white dark:bg-slate-900 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-iskcon-500 sm:text-sm transition-all appearance-none cursor-pointer">
                        <option value="" disabled selected>Select Interface Language</option>
                        <option value="en">English</option>
                        <option value="hi">हिंदी (Hindi)</option>
                        <option value="mr">मराठी (Marathi)</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-slate-400"><i class="fa-solid fa-chevron-down text-xs"></i></div>
                </div>

                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-envelope text-slate-400"></i></div>
                    <input type="email" id="email" required class="block w-full pl-10 pr-3 py-3 border border-slate-300 dark:border-slate-700 rounded-xl leading-5 bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-iskcon-500 sm:text-sm transition-all" placeholder="Authority Email Address">
                </div>

                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-lock text-slate-400"></i></div>
                    <input type="password" id="password" required class="block w-full pl-10 pr-3 py-3 border border-slate-300 dark:border-slate-700 rounded-xl leading-5 bg-white dark:bg-slate-900 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-iskcon-500 sm:text-sm transition-all" placeholder="Secure Password">
                </div>

                <button type="submit" id="loginBtn" class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-xl shadow-lg text-sm font-bold text-white bg-gradient-to-r from-iskcon-600 to-iskcon-500 hover:from-iskcon-500 hover:to-orange-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-iskcon-500 transition-all transform hover:-translate-y-1 mt-2">
                    <i class="fa-solid fa-shield-check mr-2"></i> <span data-i18n="authBtn">Secure Authenticate</span>
                </button>
            </form>
            
            <p class="mt-5 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 flex items-center justify-center gap-2">
                <i class="fa-solid fa-user-shield"></i> <span data-i18n="ipLog">IP, Device & Location Monitored</span>
            </p>
        </div>
    </div>

    <!-- MAIN DASHBOARD -->
    <div id="main-dashboard" style="display: none;" class="flex-1 flex flex-col w-full h-full transition-opacity duration-500">
        
        <!-- HEADER -->
        <header class="glass sticky top-0 z-40 px-4 md:px-6 py-3 flex items-center justify-between shadow-sm border-b border-slate-200/50 dark:border-slate-800/50">
            <a href="index.html" class="flex items-center gap-3 group cursor-pointer outline-none rounded-2xl focus:ring-2 focus:ring-iskcon-500">
                <div class="relative w-9 h-9 md:w-10 md:h-10 rounded-xl bg-white dark:bg-slate-800 flex items-center justify-center shadow-md group-hover:scale-105 transition-transform duration-300 overflow-hidden border border-slate-100 dark:border-slate-700">
                    <span class="text-base md:text-lg font-black text-iskcon-500 w-full h-full flex items-center justify-center bg-gradient-to-br from-iskcon-50 to-white dark:from-slate-700 dark:to-slate-800">IH</span>
                </div>
                <div>
                    <h1 class="text-base md:text-xl font-extrabold leading-tight text-slate-900 dark:text-white tracking-tight group-hover:text-iskcon-500 transition-colors truncate max-w-[150px] sm:max-w-none">ISKCON Hadapsar</h1>
                    <p data-i18n="portalTitle" class="text-[10px] md:text-xs font-semibold text-slate-500 dark:text-slate-400">Master Admin Portal</p>
                </div>
            </a>
            
            <div class="flex items-center gap-2 md:gap-4">
                
                <!-- Desktop Language Switcher -->
                <div class="relative hidden sm:block">
                    <select id="headerLangSelect" class="bg-white dark:bg-slate-800 shadow-sm border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-xs font-bold rounded-full focus:outline-none focus:ring-2 focus:ring-iskcon-500 block px-3 py-1.5 cursor-pointer appearance-none pr-7 transition-all hover:text-iskcon-500">
                        <option value="en">ENG</option>
                        <option value="hi">हिंदी</option>
                        <option value="mr">मराठी</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-2.5 pointer-events-none text-slate-400"><i class="fa-solid fa-language text-sm"></i></div>
                </div>

                <!-- Theme Toggle Button -->
                <button id="themeToggle" class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-white dark:bg-slate-800 shadow-sm border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-500 hover:text-iskcon-500 hover:shadow-md transition-all duration-300">
                    <i class="fa-solid fa-moon dark:hidden text-sm md:text-base"></i>
                    <i class="fa-solid fa-sun hidden dark:block text-yellow-400 text-sm md:text-base"></i>
                </button>

                <!-- Desktop Profile & Logout -->
                <div class="hidden sm:flex items-center gap-3 pl-3 md:pl-4 border-l border-slate-200 dark:border-slate-700">
                    <div class="text-right">
                        <p id="adminUserDisplay" class="text-sm font-bold text-slate-900 dark:text-white">Admin</p>
                        <p class="text-[10px] font-semibold text-iskcon-500 flex items-center justify-end gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span> <span data-i18n="superAdmin">Super Admin</span></p>
                    </div>
                    <div class="w-9 h-9 rounded-full shadow-sm border-2 border-white dark:border-slate-800 overflow-hidden">
                        <img id="adminAvatar" src="https://ui-avatars.com/api/?name=Admin&background=f97316&color=fff&bold=true" alt="Admin" class="w-full h-full object-cover">
                    </div>
                    <button id="logoutBtn" title="Secure Logout" class="w-8 h-8 ml-1 flex items-center justify-center rounded-lg bg-red-50 text-red-600 hover:bg-red-600 hover:text-white dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-600 dark:hover:text-white transition-colors duration-300">
                        <i class="fa-solid fa-power-off text-sm"></i>
                    </button>
                </div>

                <!-- Mobile Hamburger Menu Button -->
                <button id="mobileMenuBtn" class="sm:hidden w-8 h-8 flex items-center justify-center text-slate-700 dark:text-slate-300 hover:text-iskcon-500 focus:outline-none">
                    <i class="fa-solid fa-bars text-xl"></i>
                </button>
            </div>
        </header>

        <!-- MOBILE MENU DRAWER (Hidden by default) -->
        <div id="mobileMenuOverlay" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[100] opacity-0 pointer-events-none sm:hidden">
            <div id="mobileMenuDrawer" class="absolute top-0 right-0 w-64 h-full bg-white dark:bg-slate-900 shadow-2xl border-l border-slate-200 dark:border-slate-800 flex flex-col transform translate-x-full">
                <div class="p-4 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center bg-slate-50 dark:bg-slate-800/50">
                    <h3 class="font-bold text-slate-800 dark:text-white">Menu</h3>
                    <button id="closeMobileMenu" class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-red-100 hover:text-red-600 transition-colors">
                        <i class="fa-solid fa-xmark text-lg"></i>
                    </button>
                </div>
                
                <div class="p-5 flex flex-col gap-6 flex-1 overflow-y-auto">
                    <!-- Profile Info -->
                    <div class="flex items-center gap-3 p-3 rounded-xl bg-iskcon-50 dark:bg-iskcon-900/20 border border-iskcon-100 dark:border-iskcon-800/50">
                        <div class="w-12 h-12 rounded-full shadow-sm border-2 border-white dark:border-slate-800 overflow-hidden shrink-0">
                            <img id="mobileAdminAvatar" src="" alt="Admin" class="w-full h-full object-cover">
                        </div>
                        <div class="overflow-hidden">
                            <p id="mobileAdminUserDisplay" class="text-base font-bold text-slate-900 dark:text-white truncate">Admin</p>
                            <p class="text-xs font-semibold text-iskcon-500 flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span> <span data-i18n="superAdmin">Super Admin</span></p>
                        </div>
                    </div>

                    <!-- Language Switcher Mobile -->
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Interface Language</label>
                        <div class="relative">
                            <select id="mobileLangSelect" class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 text-sm font-bold rounded-xl focus:outline-none focus:ring-2 focus:ring-iskcon-500 block px-4 py-3 cursor-pointer appearance-none transition-all">
                                <option value="en">English (ENG)</option>
                                <option value="hi">हिंदी (Hindi)</option>
                                <option value="mr">मराठी (Marathi)</option>
                            </select>
                            <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-slate-400"><i class="fa-solid fa-language text-lg"></i></div>
                        </div>
                    </div>
                </div>

                <!-- Logout Button Mobile -->
                <div class="p-5 border-t border-slate-200 dark:border-slate-800 mt-auto">
                    <button id="mobileLogoutBtn" class="w-full py-3 rounded-xl bg-red-50 text-red-600 hover:bg-red-600 hover:text-white dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-600 dark:hover:text-white transition-colors duration-300 font-bold flex items-center justify-center gap-2 shadow-sm">
                        <i class="fa-solid fa-power-off"></i> Secure Logout
                    </button>
                </div>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <main class="flex-1 w-full max-w-7xl mx-auto px-4 md:px-6 py-6 flex flex-col gap-5 md:gap-6">
            
            <!-- WARNING MESSAGE -->
            <div class="w-full opacity-0 animate-fade-in-up">
                <div class="relative overflow-hidden glass rounded-2xl border-l-4 md:border-l-8 border-l-red-500 p-4 md:p-5 shadow-lg dark:bg-red-950/20">
                    <div class="absolute -right-6 -top-6 text-red-500/5 dark:text-red-500/5 z-0"><i class="fa-solid fa-shield-halved text-6xl md:text-8xl"></i></div>
                    <div class="relative z-10 flex flex-col md:flex-row items-start gap-3 md:gap-4">
                        <div class="flex-shrink-0 w-8 h-8 md:w-10 md:h-10 rounded-full bg-red-100 dark:bg-red-900/50 flex items-center justify-center text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 shadow-sm animate-pulse-slow"><i class="fa-solid fa-triangle-exclamation text-sm md:text-lg"></i></div>
                        <div class="flex-1">
                            <h3 data-i18n="warnTitle" class="text-base md:text-xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-1">⚠️ Hare Krishna! Highly Secured Master Portal</h3>
                            <p data-i18n="warnDesc" class="text-xs md:text-sm font-semibold text-slate-700 dark:text-slate-300 leading-relaxed mb-2">This is the <span class="text-red-600 dark:text-red-400 font-bold">Strictly Confidential & Official Master Admin Panel</span> of ISKCON Hadapsar.</p>
                            <p data-i18n="warnNotice" class="text-[10px] md:text-xs font-medium text-slate-600 dark:text-slate-400 bg-slate-100/80 dark:bg-slate-800/60 p-2 md:p-2.5 rounded-lg border border-slate-200 dark:border-slate-700/50 leading-snug">
                                <i class="fa-solid fa-radar text-iskcon-500 mr-1"></i> <strong class="text-slate-800 dark:text-slate-200">Security Notice:</strong> Our advanced firewall tracks every IP, Device and Location. Unauthorized access attempts will result in a <strong class="text-red-600 dark:text-red-400">Permanent Block & Police Action</strong>.<br><span class="text-iskcon-600 dark:text-iskcon-400 font-bold italic mt-1 block">"As this is highly sensitive service of Lord Krishna, please maintain decorum and security. Thank you! 🙏"</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center opacity-0 animate-fade-in-up delay-100 mt-1 mb-2">
                <div class="inline-flex items-center gap-1.5 md:gap-2 px-2.5 md:px-3 py-1 md:py-1.5 rounded-full bg-iskcon-50 dark:bg-iskcon-900/30 text-iskcon-600 dark:text-iskcon-400 font-bold text-[10px] md:text-xs mb-2 md:mb-3 border border-iskcon-100 dark:border-iskcon-800 shadow-sm">
                    <i class="fa-solid fa-star text-yellow-500"></i> <span data-i18n="hubActive">Central Control Hub Active</span>
                </div>
                <h2 data-i18n="welcomeTitle" class="text-2xl md:text-4xl font-extrabold text-slate-900 dark:text-white mb-1 md:mb-2 tracking-tight">Welcome to Master Command 🙏</h2>
                <p data-i18n="welcomeDesc" class="text-xs md:text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-medium px-2">Select a module below to access and manage its specific functions.</p>
            </div>

            <!-- MODULES GRID (WITH ONCLICK ACTIVITY TRACKING) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6 pb-6">
                
                <div onclick="navigateWithLog('Daily Darshan', 'darshan.html')" class="module-card group opacity-0 animate-fade-in-up delay-100 block bg-white/80 dark:bg-darkcard/80 backdrop-blur-xl rounded-2xl p-4 md:p-5 border border-slate-200 dark:border-slate-800 outline-none overflow-hidden">
                    <i class="fa-solid fa-camera-retro absolute -bottom-4 -right-4 md:-bottom-6 md:-right-6 text-7xl md:text-8xl text-slate-100 dark:text-slate-800/40 group-hover:text-blue-50 transition-colors z-0"></i><div class="relative z-10 flex flex-col h-full"><div class="card-icon w-12 h-12 md:w-14 md:h-14 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 text-blue-600 flex items-center justify-center text-xl md:text-2xl mb-3 md:mb-4 border border-white"><i class="fa-solid fa-image"></i></div><h3 data-i18n="modDarshanTitle" class="text-lg md:text-xl font-bold text-slate-900 dark:text-white mb-1.5 md:mb-2">Daily Darshan</h3><p data-i18n="modDarshanDesc" class="text-[11px] md:text-sm font-medium text-slate-500 dark:text-slate-400 flex-1 mb-4 md:mb-6 leading-relaxed">Upload and manage daily deity pictures.</p><div class="flex items-center text-[10px] md:text-xs font-bold text-blue-600 bg-blue-50 w-max px-2.5 py-1.5 md:px-3 md:py-1.5 rounded-lg group-hover:bg-blue-600 group-hover:text-white transition-all shadow-sm mt-auto"><span data-i18n="accessBtn">Access Module</span><i class="fa-solid fa-arrow-right ml-1.5 md:ml-2 group-hover:translate-x-1"></i></div></div>
